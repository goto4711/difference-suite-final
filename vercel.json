{
    "buildCommand": "npm run build:consolidated",
    "outputDirectory": "dist",
    "framework": "vite",
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cross-Origin-Opener-Policy",
                    "value": "same-origin"
                },
                {
                    "key": "Cross-Origin-Embedder-Policy",
                    "value": "require-corp"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/difference-suite-large-models/:path*",
            "destination": "/difference-suite-large-models/index.html"
        }
    ]
}